# Wymusza `engines.node` z package.json przy `npm install` / `npm ci`.
# mcp-devtools wymaga Node 22+ (natywny fetch, AbortSignal.any, ESM top-level await).
engine-strict=true

# Bezpieczniejszy default — `npm audit` nie blokuje instalacji, ale ostrzega.
audit-level=high

# Twardy fail na peer-dependency mismatch (zamiast cichego automaticznego rozwiązania).
legacy-peer-deps=false

# Save exact (bez ^) dla deterministycznych instalacji — pasuje do polityki `npm ci` w CI.
save-exact=false
