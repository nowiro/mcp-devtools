# Wymusza `engines.node` z package.json przy `npm install` / `npm ci`.
# mcp-devtools wymaga Node 22.22.1+ (lint-staged 17.0.5 minimum, plus
# natywny fetch / AbortSignal.any / ESM top-level await z Node 22 family).
engine-strict=true

# Bezpieczniejszy default — `npm audit` nie blokuje instalacji, ale ostrzega.
audit-level=high

# Twardy fail na peer-dependency mismatch (zamiast cichego automaticznego rozwiązania).
legacy-peer-deps=false

# Pin policy — `npm install <pkg>` zapisuje exact version (bez `^`).
# Mirror do polityki pinningu w package.json. `npm ci` w CI dostaje
# byte-identyczne node_modules niezależnie od momentu instalacji.
save-exact=true
