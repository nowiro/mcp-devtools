{
  "name": "@nowiro/mcp-devtools",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server with developer-workflow tools (analyze_code, propose_fix, run_playwright, compliance_report). Multi-framework (Angular / React / Vue auto-detect). Cross-platform — Windows / macOS / Linux. Compatible with GitHub Copilot in VS Code >= 1.121 and IntelliJ IDEA >= 2026.1.2.",
  "license": "MIT",
  "homepage": "https://github.com/nowiro/mcp-devtools#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nowiro/mcp-devtools.git"
  },
  "bugs": {
    "url": "https://github.com/nowiro/mcp-devtools/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "github-copilot",
    "copilot",
    "developer-tools",
    "static-analysis",
    "playwright",
    "compliance",
    "typescript",
    "angular",
    "react",
    "vue"
  ],
  "engines": {
    "node": ">=22.22.1"
  },
  "packageManager": "npm@11.16.0",
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "mcp-devtools": "./dist/server.js",
    "mcp-devtools-cdk": "./dist/cli/mcp-devtools-cdk.js"
  },
  "scripts": {
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "bootstrap": "node tools/scripts/bootstrap.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md,yml,yaml}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "start": "node dist/server.js",
    "commit": "cz",
    "doctor": "node tools/scripts/doctor.mjs",
    "ai:validate": "node tools/scripts/validate-ai-config.mjs",
    "template:render": "node tools/scripts/render-template.mjs",
    "template:list": "node tools/scripts/render-template.mjs --list",
    "validate:inputs": "node tools/scripts/validate-inputs.mjs",
    "token:budget": "node tools/scripts/token-budget.mjs",
    "workflow:new-tool": "node tools/scripts/workflow-new-tool.mjs",
    "workflow:audit-sandbox": "node tools/scripts/workflow-audit-sandbox.mjs",
    "extract:analyze": "node dist/extract-analyze.js",
    "extract:compliance": "node dist/extract-compliance.js",
    "cdk:compile": "node dist/cli/mcp-devtools-cdk.js compile",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build && npm run ai:validate && npm run validate:inputs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "handlebars": "4.7.9",
    "zod": "4.4.3",
    "zod-to-json-schema": "3.25.2"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@commitlint/types": "21.0.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@types/node": "25.9.1",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/eslint-plugin": "1.6.18",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-security": "4.0.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
